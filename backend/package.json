{
  "name": "weather-report-backend",
  "version": "1.0.0",
  "description": "Backend for Weather Report application",
  "main": "dist/index.js",
  "scripts": {
    "dev": "yarn db:push && npx nodemon src/index.ts",
    "start": "dotenvx run -- node dist/index.js",
    "build": "yarn db:push && yarn tsc && yarn tsc-alias",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "db:push": "dotenvx run -- npx prisma db push",
    "copy-assets-files": "copyfiles -u 1 ./src/**/*.{json,pdf,jpg,png,jpeg,html,ejs,css} dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apollo/server": "4.10.4",
    "@apollo/utils.keyvadapter": "3.1.0",
    "@aws-sdk/client-s3": "3.572.0",
    "@aws-sdk/s3-request-presigner": "3.572.0",
    "@dotenvx/dotenvx": "1.5.0",
    "@graphql-tools/load-files": "7.0.0",
    "@graphql-tools/merge": "9.0.4",
    "@graphql-tools/schema": "10.0.3",
    "@prisma/client": "5.17.0",
    "axios": "1.7.9",
    "bcryptjs": "2.4.3",
    "body-parser": "1.20.2",
    "cookie-parser": "1.4.6",
    "cors": "2.8.5",
    "crypto": "^1.0.1",
    "dataloader": "2.2.2",
    "dayjs": "1.11.13",
    "ejs": "3.1.10",
    "express": "4.19.2",
    "express-basic-auth": "1.2.1",
    "express-slow-down": "2.0.3",
    "graphql": "16.8.1",
    "graphql-redis-subscriptions": "2.7.0",
    "graphql-scalars": "1.23.0",
    "graphql-subscriptions": "3.0.0",
    "graphql-ws": "5.16.0",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "keyv": "4.5.4",
    "lodash": "4.17.21",
    "mongodb": "6.6.1",
    "nodemailer": "6.9.13",
    "otpauth": "9.3.5",
    "prisma": "5.16.0",
    "prisma-extension-soft-delete": "1.0.1",
    "qs": "6.12.1",
    "twilio": "5.4.0",
    "ws": "8.17.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@swc/core": "1.5.5",
    "@swc/helpers": "0.5.11",
    "@tsconfig/node18": "18.2.4",
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "1.4.7",
    "@types/cors": "2.8.17",
    "@types/ejs": "3.1.5",
    "@types/jsonwebtoken": "9.0.6",
    "@types/lodash": "4.17.1",
    "@types/node": "20.12.11",
    "@types/nodemailer": "6.4.15",
    "@types/ws": "8.5.10",
    "@typescript-eslint/eslint-plugin": "7.8.0",
    "@typescript-eslint/parser": "7.8.0",
    "concurrently": "8.2.2",
    "copyfiles": "2.4.1",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "nodemon": "3.1.0",
    "prettier": "3.2.5",
    "regenerator-runtime": "0.14.1",
    "rimraf": "6.0.1",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.8",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.4.5"
  },
  "prisma": {
    "seed": "dotenvx run -- npx ts-node src/database/seed.ts",
    "schema": "./prisma"
  }
}
